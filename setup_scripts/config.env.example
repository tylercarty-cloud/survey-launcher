# SurveySparrow-Zendesk ZIS Integration Configuration
# ====================================================
# Copy this file to config.env and fill in your values

# Zendesk Configuration
# ---------------------
# Your Zendesk subdomain (e.g., if your URL is https://mycompany.zendesk.com, use "mycompany")
ZENDESK_SUBDOMAIN="your_subdomain"

# Zendesk admin email address
ZENDESK_EMAIL="admin@yourcompany.com"

# Zendesk API token (generate at Admin Center > Apps and integrations > APIs > Zendesk API)
ZENDESK_API_TOKEN="your_zendesk_api_token"

# SurveySparrow Configuration
# ---------------------------
# SurveySparrow API token (generate at Settings > Apps & Integrations > API)
SURVEYSPARROW_API_TOKEN="your_surveysparrow_api_token"

# Survey Configuration
# --------------------
# Your survey's base URL (the share link without any parameters)
# Example: https://yourcompany.surveysparrow.com/s/customer-feedback
SURVEY_BASE_URL="https://yourcompany.surveysparrow.com/s/your-survey-name"

# Your survey ID (visible in the SurveySparrow dashboard or API)
SURVEY_ID="1000461299"

# Optional: Channel ID (if using the unique links API)
# CHANNEL_ID=""

# Bundle Configuration
# --------------------
# Which bundle file to use (default is ../zis_bundle.json)
# Use ../zis_bundle_with_webhook.json for on-demand webhook support
BUNDLE_FILE="../zis_bundle.json"
